# Credenciales del bot de Telegram (obligatorio)
# Obtén tu token del bot en @BotFather de Telegram
TELEGRAM_BOT_TOKEN=tu_token_aqui
# Obtén tu chat ID en @userinfobot de Telegram
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# Intervalo de comprobación en minutos (opcional, por defecto: 10)
CHECK_INTERVAL_MINUTES=10

# URL inicial de la página de cita (opcional)
CITA_DNI_URL=https://www.citapreviadnie.es/citaPreviaDni/Inicio.action

# Mes máximo aceptable para la cita (opcional)
# Valores válidos: enero, febrero, marzo, abril, mayo, junio,
#                  julio, agosto, septiembre, octubre, noviembre, diciembre
# Dejar vacío para recibir notificaciones de cualquier mes disponible
MAX_MONTH=
